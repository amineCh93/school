# Main API
PORT=3000
MONGODB_URI=mongodb://127.0.0.1:27017/school_management
AUTH_SECRET=replace-with-a-strong-secret
AUTH_ISSUER=school-management-api
AUTH_AUDIENCE=school-management-clients
BCRYPT_ROUNDS=12
NOTIFICATION_SERVICE_URL=http://127.0.0.1:4000
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000
PUBLIC_RATE_LIMIT_WINDOW_MS=900000
PUBLIC_RATE_LIMIT_MAX=200

# Notification microservice (if run from the same root env)
NOTIFICATION_PORT=4000
SKIP_DB=false
NOTIFICATION_MONGODB_URI=mongodb://127.0.0.1:27017/notification_service
NOTIFICATION_CORS_ORIGIN=http://localhost:3000
